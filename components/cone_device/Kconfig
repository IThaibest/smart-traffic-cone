menu "Cone device modules"

config CONE_DEVICE_ENABLE_GPS
    bool "Enable GPS module"
    default n
    help
        Build the generic GPS positioning module interface.

config CONE_DEVICE_ENABLE_ULTRASONIC_ARRAY
    bool "Enable four-channel ultrasonic array"
    default n
    help
        Build the generic four-channel ultrasonic distance module interface.

config CONE_DEVICE_ENABLE_CAMERA
    bool "Enable camera module"
    default n
    help
        Build the generic camera status and capture module interface.

endmenu
