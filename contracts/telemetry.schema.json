{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Intelligent-Traffic-Cone/smart-traffic-cone/contracts/telemetry.schema.json",
  "title": "ConeTelemetry",
  "type": "object",
  "required": ["cone_id", "reported_at", "location", "ultrasonic", "camera", "device"],
  "additionalProperties": false,
  "properties": {
    "cone_id": {
      "type": "string",
      "minLength": 1
    },
    "reported_at": {
      "type": "string",
      "format": "date-time"
    },
    "location": {
      "type": "object",
      "required": ["has_fix"],
      "additionalProperties": false,
      "properties": {
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "accuracy_m": { "type": ["number", "null"], "minimum": 0 },
        "has_fix": { "type": "boolean" }
      }
    },
    "ultrasonic": {
      "type": "array",
      "minItems": 0,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["channel", "timed_out"],
        "additionalProperties": false,
        "properties": {
          "channel": { "type": "integer", "minimum": 0, "maximum": 3 },
          "distance_m": { "type": ["number", "null"], "minimum": 0 },
          "timed_out": { "type": "boolean" },
          "sample_age_ms": { "type": ["integer", "null"], "minimum": 0 }
        }
      }
    },
    "camera": {
      "type": "object",
      "required": ["enabled", "initialized", "frame_available", "frame_count"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "initialized": { "type": "boolean" },
        "frame_available": { "type": "boolean" },
        "last_frame_age_ms": { "type": ["integer", "null"], "minimum": 0 },
        "frame_count": { "type": "integer", "minimum": 0 },
        "image_url": { "type": ["string", "null"] }
      }
    },
    "device": {
      "type": "object",
      "required": ["gps_status", "ultrasonic_status", "camera_status", "network_status"],
      "additionalProperties": false,
      "properties": {
        "gps_status": { "type": "string" },
        "ultrasonic_status": { "type": "string" },
        "camera_status": { "type": "string" },
        "network_status": { "type": "string" },
        "battery_percent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
      }
    },
    "raw_payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
