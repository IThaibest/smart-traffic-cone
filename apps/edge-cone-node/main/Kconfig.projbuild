menu "Smart Traffic Cone Node"

config CONE_NODE_ID
    string "Cone node id"
    default "cone-demo-001"
    help
        Stable id used in telemetry and cloud device records.

config CONE_NODE_TELEMETRY_INTERVAL_MS
    int "Telemetry upload interval in milliseconds"
    default 3000
    range 500 60000
    help
        Product-level interval for building and sending telemetry snapshots.

endmenu
